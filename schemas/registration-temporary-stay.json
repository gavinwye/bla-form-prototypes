{
  "id": "registration-temporary-stay",
  "name": "Register Your Vehicle for a Temporary Stay in Barbados",
  "description": "Register a vehicle for temporary use during a stay in Barbados",
  "fields": [
    {
      "name": "applicant",
      "type": "object",
      "label": "Applicant details",
      "required": true,
      "fields": [
        {
          "name": "fullName",
          "type": "string",
          "label": "Full name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "address",
          "type": "string",
          "label": "Address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 500
          }
        },
        {
          "name": "email",
          "type": "email",
          "label": "Email address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 254
          }
        },
        {
          "name": "contactNumber",
          "type": "string",
          "label": "Contact number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 20
          }
        }
      ]
    },
    {
      "name": "vehicle",
      "type": "object",
      "label": "Vehicle details",
      "required": true,
      "fields": [
        {
          "name": "make",
          "type": "string",
          "label": "Make",
          "required": true,
          "validations": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "model",
          "type": "string",
          "label": "Model",
          "required": true,
          "validations": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "year",
          "type": "string",
          "label": "Year",
          "required": true,
          "validations": {
            "regex": "^\\d{4}$"
          }
        },
        {
          "name": "colour",
          "type": "string",
          "label": "Colour",
          "required": true,
          "validations": {
            "min": 1,
            "max": 50
          }
        }
      ]
    },
    {
      "name": "vehicleIdentification",
      "type": "object",
      "label": "Vehicle identification",
      "required": true,
      "fields": [
        {
          "name": "chassisNumber",
          "type": "string",
          "label": "Chassis number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 30
          }
        },
        {
          "name": "engineNumber",
          "type": "string",
          "label": "Engine number",
          "required": false,
          "validations": {
            "max": 30
          }
        },
        {
          "name": "motorNumber",
          "type": "string",
          "label": "Motor number",
          "required": false,
          "validations": {
            "max": 30
          }
        }
      ]
    },
    {
      "name": "fuelType",
      "type": "string",
      "label": "Fuel type",
      "required": true,
      "validations": {
        "regex": "^(petrol|diesel|electric|hybrid|cng|lpg)$"
      }
    },
    {
      "name": "steeringConfiguration",
      "type": "string",
      "label": "Steering configuration",
      "required": true,
      "validations": {
        "regex": "^(left-hand|right-hand)$"
      }
    },
    {
      "name": "insurance",
      "type": "object",
      "label": "Insurance details",
      "required": true,
      "fields": [
        {
          "name": "insurerName",
          "type": "string",
          "label": "Insurer name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "policyNumber",
          "type": "string",
          "label": "Policy number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 50
          }
        },
        {
          "name": "insuranceType",
          "type": "string",
          "label": "Insurance type",
          "required": true,
          "validations": {
            "regex": "^(green-card|local)$"
          }
        }
      ]
    },
    {
      "name": "declaration",
      "type": "object",
      "label": "Declaration",
      "required": true,
      "fields": [
        {
          "name": "agreed",
          "type": "boolean",
          "label": "I agree to the terms and conditions",
          "required": true
        }
      ]
    }
  ],
  "processors": [
    {
      "type": "email",
      "config": {
        "to": "{{db:registration-temporary-stay:admin_email}}",
        "template": "registration-temporary-stay-admin",
        "subject": "New Temporary Stay Vehicle Registration Application"
      }
    },
    {
      "type": "email",
      "config": {
        "to": "{{formData.applicant.email}}",
        "template": "registration-temporary-stay-applicant",
        "subject": "Your Temporary Stay Vehicle Registration Has Been Received"
      }
    }
  ]
}
