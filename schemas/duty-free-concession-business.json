{
  "id": "duty-free-concession-business",
  "name": "Request for Duty Free Concession (Business)",
  "description": "Apply for a duty free concession on a vehicle for a business",
  "fields": [
    {
      "name": "business",
      "type": "object",
      "label": "Business details",
      "required": true,
      "fields": [
        {
          "name": "name",
          "type": "string",
          "label": "Business name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "address",
          "type": "string",
          "label": "Business address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 500
          }
        },
        {
          "name": "telephone",
          "type": "string",
          "label": "Telephone number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 20
          }
        },
        {
          "name": "email",
          "type": "email",
          "label": "Email address",
          "required": true
        }
      ]
    },
    {
      "name": "authorisedPerson",
      "type": "object",
      "label": "Authorised person",
      "required": true,
      "fields": [
        {
          "name": "fullName",
          "type": "string",
          "label": "Full name of authorised person",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "businessName",
          "type": "string",
          "label": "Business name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        }
      ]
    },
    {
      "name": "vehicle",
      "type": "object",
      "label": "Vehicle details",
      "required": true,
      "fields": [
        {
          "name": "registrationNumber",
          "type": "string",
          "label": "Registration number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 20
          }
        },
        {
          "name": "engineNumber",
          "type": "string",
          "label": "Engine number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 30
          }
        },
        {
          "name": "chassisNumber",
          "type": "string",
          "label": "Chassis number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 30
          }
        },
        {
          "name": "year",
          "type": "string",
          "label": "Year of manufacture",
          "required": true,
          "validations": {
            "regex": "^\\d{4}$"
          }
        },
        {
          "name": "vehicleType",
          "type": "string",
          "label": "Vehicle type",
          "required": true,
          "validations": {
            "min": 1,
            "max": 50
          }
        }
      ]
    }
  ],
  "processors": [
    {
      "type": "email",
      "config": {
        "to": "{{db:duty-free-concession-business:admin_email}}",
        "template": "duty-free-concession-business-admin",
        "subject": "New Duty Free Concession Application (Business)"
      }
    },
    {
      "type": "email",
      "config": {
        "to": "{{formData.business.email}}",
        "template": "duty-free-concession-business-applicant",
        "subject": "Your Duty Free Concession Application Has Been Received"
      }
    }
  ]
}
