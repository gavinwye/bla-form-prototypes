{
  "id": "sale-of-vehicle-individual",
  "name": "Sale of Vehicle (Individual Owner)",
  "description": "Notify the Barbados Licensing Authority of the sale of a vehicle by an individual owner",
  "fields": [
    {
      "name": "seller",
      "type": "object",
      "label": "Seller details",
      "required": true,
      "fields": [
        {
          "name": "fullName",
          "type": "string",
          "label": "Full name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "address",
          "type": "string",
          "label": "Address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 500
          }
        },
        {
          "name": "idNumber",
          "type": "string",
          "label": "ID number / National Registration Number",
          "required": true,
          "validations": {
            "regex": "^\\d{6}-\\d{4}$"
          }
        },
        {
          "name": "telephone",
          "type": "string",
          "label": "Telephone",
          "required": true,
          "validations": {
            "min": 1,
            "max": 20
          }
        },
        {
          "name": "email",
          "type": "email",
          "label": "Email address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 254
          }
        }
      ]
    },
    {
      "name": "vehicle",
      "type": "object",
      "label": "Vehicle details",
      "required": true,
      "fields": [
        {
          "name": "registrationNumber",
          "type": "string",
          "label": "Registration number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 20
          }
        },
        {
          "name": "engineNumber",
          "type": "string",
          "label": "Engine number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 30
          }
        },
        {
          "name": "chassisNumber",
          "type": "string",
          "label": "Chassis number",
          "required": true,
          "validations": {
            "min": 1,
            "max": 30
          }
        },
        {
          "name": "make",
          "type": "string",
          "label": "Make",
          "required": true,
          "validations": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "model",
          "type": "string",
          "label": "Model",
          "required": true,
          "validations": {
            "min": 1,
            "max": 100
          }
        }
      ]
    },
    {
      "name": "buyer",
      "type": "object",
      "label": "Buyer details",
      "required": true,
      "fields": [
        {
          "name": "fullName",
          "type": "string",
          "label": "Full name",
          "required": true,
          "validations": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "address",
          "type": "string",
          "label": "Address",
          "required": true,
          "validations": {
            "min": 1,
            "max": 500
          }
        }
      ]
    },
    {
      "name": "retainRegistration",
      "type": "string",
      "label": "Retain registration number",
      "required": true,
      "validations": {
        "regex": "^(yes|no)$"
      }
    }
  ],
  "processors": [
    {
      "type": "email",
      "config": {
        "to": "{{db:sale-of-vehicle-individual:admin_email}}",
        "template": "sale-of-vehicle-individual-admin",
        "subject": "New Sale of Vehicle Notification (Individual Owner)"
      }
    },
    {
      "type": "email",
      "config": {
        "to": "{{formData.seller.email}}",
        "template": "sale-of-vehicle-individual-applicant",
        "subject": "Your Vehicle Sale Notification Has Been Received"
      }
    }
  ]
}
